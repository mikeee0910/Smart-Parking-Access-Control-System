[Unit]
Description=Smart Parking - STM32 WiFi bridge (Flask :5001)
Wants=network-online.target
After=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__APP_DIR__
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 __APP_DIR__/stm32_wifi_server.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
