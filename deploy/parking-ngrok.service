[Unit]
Description=Smart Parking - ngrok tunnel for :5000
Wants=network-online.target
After=network-online.target parking-app.service
StartLimitIntervalSec=0

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__APP_DIR__
ExecStart=__NGROK_BIN__ http --url=nonatheistical-dissidently-shameka.ngrok-free.dev 5000 --log=stdout --log-format=logfmt
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
